---
/**
 * Papers board — /papers/
 *
 * Lists every entry from the `domestic-papers` content collection, sorted by
 * year desc. These are domestic-workshop / domestic-journal publications —
 * including in-progress work and earlier versions of papers that later
 * matured into the international Publications on the home page.
 */
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import DomesticPaperCard from '../../components/DomesticPaperCard.astro';
import Footer from '../../components/Footer.astro';
import microcopy from '../../data/microcopy.json';

// ─── Data loading ─────────────────────────────────────────────────────
const profileEntry = await getEntry('profile', 'profile');
const profile = profileEntry?.data;

const papers = await getCollection('domestic-papers');

const sortedPapers = [...papers].sort((a, b) => {
  if (b.data.year !== a.data.year) return b.data.year - a.data.year;
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return a.data.title.localeCompare(b.data.title);
});

// ─── Page metadata ────────────────────────────────────────────────────
const authorName = profile?.name.display ?? 'Yoojin Jang';
const pageTitle = `Papers — ${authorName}`;
const pageDescription =
  'Domestic workshop and journal papers by Yoojin Jang — including in-progress work and earlier versions.';
const subhead =
  'Domestic workshops and journals — including in-progress work and earlier versions.';

const canonicalUrl = 'https://hellog2n.github.io/papers/';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
>
  <ThemeToggle />

  <main class="min-h-screen">
    <section
      class="pt-10 pb-10 md:pt-16 md:pb-12"
      aria-labelledby="papers-heading"
    >
      <div class="mx-auto max-w-content px-5 sm:px-6 lg:px-8">
        <header class="mb-10 md:mb-12">
          <h1
            id="papers-heading"
            class="text-h1 font-semibold tracking-tight text-primary leading-tight"
          >
            Papers
          </h1>
          <p class="mt-3 text-small leading-normal text-muted">{subhead}</p>
        </header>

        {
          sortedPapers.length > 0 ? (
            <ol class="flex flex-col gap-3 list-none p-0 m-0">
              {sortedPapers.map((entry) => (
                <li>
                  <DomesticPaperCard entry={entry} />
                </li>
              ))}
            </ol>
          ) : (
            <p class="text-small text-muted">No papers yet.</p>
          )
        }
      </div>
    </section>
  </main>

  <Footer
    authorName={authorName}
    tagline={(microcopy as Record<string, string>)['footer.tagline']}
  />
</Layout>
