---
/**
 * Footer — minimal close.
 * One line: copyright · build credit · tagline.
 */
export interface Props {
  authorName: string;
  tagline?: string;
}

const { authorName, tagline } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-subtle mt-12 py-8 md:py-12">
  <div
    class="mx-auto max-w-content px-5 sm:px-6 lg:px-8 flex flex-col items-center gap-2 text-micro text-muted leading-normal md:flex-row md:justify-center md:gap-4"
  >
    <span>&copy; {year} {authorName}</span>
    <span aria-hidden="true" class="hidden md:inline">·</span>
    <span>
      Built with{' '}
      <a
        href="https://claude.com/claude-code"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted hover:text-accent-hover hover:underline underline-offset-[3px] decoration-1 transition-colors duration-fast ease-standard"
      >
        Claude Code
      </a>
    </span>
    {
      tagline && (
        <>
          <span aria-hidden="true" class="hidden md:inline">
            ·
          </span>
          <span>{tagline}</span>
        </>
      )
    }
  </div>
</footer>
