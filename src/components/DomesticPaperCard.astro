---
/**
 * DomesticPaperCard — one domestic paper row on the /papers page.
 *
 * Compact row, similar chrome to ProjectCard/CareerCard. Domestic-paper
 * entries are venue-anchored, so the layout emphasizes:
 *   - title (and optional Korean subtitle)
 *   - venue · venue_iteration · year
 *   - honors pill (when present)
 *
 * Data contract: src/content/domestic-papers/*.json validated against the
 * `domestic-papers` collection schema in src/content/config.ts.
 */
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'domestic-papers'>;
}

const { entry } = Astro.props;
const d = entry.data;

type LinkEntry = { label: string; href: string };
const linkEntries: LinkEntry[] = [];
if (d.links?.paper) linkEntries.push({ label: 'Paper', href: d.links.paper });
if (d.links?.arxiv) linkEntries.push({ label: 'arXiv', href: d.links.arxiv });
if (d.links?.slides) linkEntries.push({ label: 'Slides', href: d.links.slides });

const yearLabel = String(d.year);
const venueLine = [d.venue, d.venue_iteration].filter(Boolean).join(' · ');
---

<article
  class="paper-card group flex flex-col gap-3 rounded-lg border border-subtle bg-bg-elevated px-5 py-4 md:flex-row md:items-start md:gap-6 md:px-6 md:py-5 focus-within:shadow-focus"
  aria-labelledby={`paper-${d.id}-title`}
>
  {/* ─── Date column ─── */}
  <div class="flex shrink-0 flex-col gap-0.5 md:w-32">
    <span
      class="tabular text-small font-medium text-primary leading-snug"
      aria-label={`Year ${yearLabel}`}
    >
      <time datetime={yearLabel}>{yearLabel}</time>
    </span>
    <span class="text-micro text-muted leading-normal" lang={d.language}>
      {d.language === 'ko' ? 'Korean' : 'English'}
    </span>
  </div>

  {/* ─── Title + venue + tagline column ─── */}
  <div class="flex min-w-0 flex-1 flex-col gap-1">
    <h3
      id={`paper-${d.id}-title`}
      class="text-body font-semibold tracking-tight leading-snug text-primary"
    >
      {d.title}
    </h3>
    {
      d.title_ko && (
        <p class="text-small leading-normal text-muted" lang="ko">
          {d.title_ko}
        </p>
      )
    }
    <p class="mt-1 text-small leading-normal text-secondary">
      {venueLine}
      {
        d.venue_full && (
          <span class="text-muted"> — {d.venue_full}</span>
        )
      }
    </p>
    {
      d.tagline && (
        <p class="mt-1 text-small leading-normal text-secondary">
          {d.tagline}
        </p>
      )
    }
  </div>

  {/* ─── Honors + tags + links column ─── */}
  <div class="flex shrink-0 flex-col items-start gap-2 md:items-end md:max-w-[14rem]">
    {
      (d.honors.length > 0 || d.tags.length > 0) && (
        <ul class="flex flex-wrap gap-1.5 md:justify-end list-none p-0 m-0">
          {d.honors.map((honor) => (
            <li class="honors-pill">{honor}</li>
          ))}
          {d.tags.map((tag) => (
            <li class="tag-pill">{tag}</li>
          ))}
        </ul>
      )
    }
    {
      linkEntries.length > 0 && (
        <p class="flex flex-wrap items-center gap-x-2 gap-y-1 text-small font-medium text-accent md:justify-end">
          {linkEntries.map((entry, i) => (
            <>
              {i > 0 && (
                <span class="text-muted" aria-hidden="true">
                  ·
                </span>
              )}
              <a
                href={entry.href}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-accent-hover hover:underline underline-offset-[3px] decoration-1 transition-colors duration-fast ease-standard"
              >
                {entry.label}
              </a>
            </>
          ))}
        </p>
      )
    }
  </div>
</article>

<style>
  .tag-pill {
    display: inline-flex;
    align-items: center;
    background-color: var(--color-bg-muted);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
    border-radius: 9999px;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.3;
    white-space: nowrap;
  }

  .paper-card {
    transition:
      border-color 150ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @media (hover: hover) {
    .paper-card:hover {
      border-color: var(--color-border-default);
      transform: translateY(-1px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .paper-card,
    .paper-card:hover {
      transform: none;
      transition-duration: 0.01ms;
    }
  }
</style>
