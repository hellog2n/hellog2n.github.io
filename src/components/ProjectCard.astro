---
/**
 * ProjectCard — one project on the /projects board.
 *
 * Layout philosophy: compact, board-style row.
 *   - More compact than PublicationCard (no thumbnail column, no authors row).
 *   - Desktop: [year/period column] [title + tagline column] [tags + links column].
 *   - Mobile: stack — year on top, title, tagline, tags at bottom.
 *
 * Hover policy (matches motion-spec.md):
 *   - border color: subtle → default
 *   - subtle 1px lift via translateY
 *   - 150ms standard easing
 *   - Touch / reduced-motion: no lift, color change only
 *
 * Data contract: src/content/projects/*.json validated against
 * the `projects` collection schema in src/content/config.ts.
 */
import type { CollectionEntry } from 'astro:content';
import ExternalLink from './icons/ExternalLink.astro';

export interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const d = project.data;

type LinkEntry = { label: string; href: string };
const linkEntries: LinkEntry[] = [];
if (d.links?.repo) linkEntries.push({ label: 'Repo', href: d.links.repo });
if (d.links?.demo) linkEntries.push({ label: 'Demo', href: d.links.demo });
if (d.links?.paper) linkEntries.push({ label: 'Paper', href: d.links.paper });

// Year label: show period if present, else year. Period contains the year already
// (e.g. "2023.12 – 2024.04"), so we don't repeat the standalone year there.
const yearLabel = String(d.year);
const periodLabel = d.period ?? null;
---

<article
  class="project-card group flex flex-col gap-3 rounded-lg border border-subtle bg-bg-elevated px-5 py-4 md:flex-row md:items-start md:gap-6 md:px-6 md:py-5 focus-within:shadow-focus"
  aria-labelledby={`project-${d.id}-title`}
>
  {/* ─── Date column ─── */}
  <div class="flex shrink-0 flex-col gap-0.5 md:w-32">
    <span
      class="tabular text-small font-medium text-primary leading-snug"
      aria-label={`Year ${yearLabel}`}
    >
      <time datetime={yearLabel}>{yearLabel}</time>
    </span>
    {
      periodLabel && (
        <span class="tabular text-micro text-muted leading-normal">
          {periodLabel}
        </span>
      )
    }
  </div>

  {/* ─── Title + tagline column ─── */}
  <div class="flex min-w-0 flex-1 flex-col gap-1">
    <h3
      id={`project-${d.id}-title`}
      class="text-body font-semibold tracking-tight leading-snug text-primary"
    >
      {d.title}
    </h3>
    {
      d.role && (
        <p class="text-micro uppercase tracking-wider text-muted font-medium">
          {d.role}
        </p>
      )
    }
    {
      d.tagline && (
        <p class="text-small leading-normal text-secondary">{d.tagline}</p>
      )
    }
    {
      d.description && (
        <p class="mt-1 text-small leading-normal text-secondary">
          {d.description}
        </p>
      )
    }
  </div>

  {/* ─── Tags + links column ─── */}
  {
    (d.tags.length > 0 || linkEntries.length > 0) && (
      <div class="flex shrink-0 flex-col items-start gap-2 md:items-end md:max-w-[14rem]">
        {d.tags.length > 0 && (
          <ul class="flex flex-wrap gap-1.5 md:justify-end list-none p-0 m-0">
            {d.tags.map((tag) => (
              <li class="tag-pill">{tag}</li>
            ))}
          </ul>
        )}
        {linkEntries.length > 0 && (
          <p class="flex flex-wrap items-center gap-x-2 gap-y-1 text-small font-medium text-accent md:justify-end">
            {linkEntries.map((entry, i) => (
              <>
                {i > 0 && (
                  <span class="text-muted" aria-hidden="true">
                    ·
                  </span>
                )}
                <a
                  href={entry.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 hover:text-accent-hover hover:underline underline-offset-[3px] decoration-1 transition-colors duration-fast ease-standard"
                >
                  <span>{entry.label}</span>
                  <ExternalLink size={11} class="opacity-60" />
                </a>
              </>
            ))}
          </p>
        )}
      </div>
    )
  }
</article>

<style>
  /* Component-scoped — tag pill style. Distinct from honors-pill (accent-tinted)
     so projects' many tags don't visually compete with paper honors. */
  .tag-pill {
    display: inline-flex;
    align-items: center;
    background-color: var(--color-bg-muted);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
    border-radius: 9999px;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.3;
    white-space: nowrap;
  }

  /* Hover lift — matches PublicationCard policy (1px, 150ms standard). */
  .project-card {
    transition:
      border-color 150ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @media (hover: hover) {
    .project-card:hover {
      border-color: var(--color-border-default);
      transform: translateY(-1px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card:hover {
      transform: none;
      transition-duration: 0.01ms;
    }
  }
</style>
